# -----------------------------------------------------------------------------
# WordPress Enterprise Security Platform - Example Environment
# -----------------------------------------------------------------------------
PROJECT_DOMAIN=ernu.sec
AUTHOR_WEBSITE=https://www.ernu.eu
TZ=Europe/Chisinau

# Server addressing
SERVER_LAN_IP=10.10.10.20
LAN_CIDR=10.10.10.0/24
NPM_ADMIN_PORT=81

# Shared MariaDB instance on the same Debian host
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD_32_CHARS
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# Nginx Proxy Manager database in the shared MariaDB instance
NPM_DB_NAME=npm
NPM_DB_USER=npm_user
NPM_DB_PASSWORD=CHANGE_ME_NPM_DB_PASSWORD_32_CHARS

# WordPress site 1
WP01_DOMAIN=wp01.ernu.sec
WP01_DB_NAME=wp01_db
WP01_DB_USER=wp01_user
WP01_DB_PASSWORD=CHANGE_ME_WP01_DB_PASSWORD_32_CHARS
WP01_BACKEND_PORT=8081
WP01_ROOT=/var/www/wp01

# WordPress site 2 optional
WP02_DOMAIN=wp02.ernu.sec
WP02_DB_NAME=wp02_db
WP02_DB_USER=wp02_user
WP02_DB_PASSWORD=CHANGE_ME_WP02_DB_PASSWORD_32_CHARS
WP02_BACKEND_PORT=8082
WP02_ROOT=/var/www/wp02

# Cloudflare DNS Challenge - DO NOT place token inside docker-compose.yml
# Store token in a password manager and paste it only inside NPM UI.
CLOUDFLARE_DNS_API_TOKEN=DO_NOT_COMMIT_REAL_TOKEN
